{
  "mcpServers": {
    "typst-docker": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-v", "/ABS/PATH/TO/YOUR/PROJECT:/app",
        "ghcr.io/vvijayaragupathy-uno/typst-mcpserver:main"
      ]
    },
    "typst-local": {
      "command": "python3",
      "args": [
        "/ABS/PATH/TO/YOUR/PROJECT/server.py"
      ]
    }
  }
}
